---
/* src/components/FooterL.astro */
---

<footer class="bg-bleu-marine py-12">
  <div class="px-6 mx-auto w-full max-w-[1600px]">
    
    <!-- Ligne 1 : Menu (Passage en wrap sur mobile pour éviter le débordement) -->
    <nav class="flex flex-wrap justify-start gap-6 lg:gap-16 pb-8">
      <a href="/" class="text-white hover:text-jaune transition-colors text-sm font-display uppercase tracking-widest">Accueil</a>
      <a href="#apropos" class="text-white hover:text-jaune transition-colors text-sm font-display uppercase tracking-widest">A propos</a>
      <a href="/mentions" class="text-white hover:text-jaune transition-colors text-sm font-display uppercase tracking-widest">Mentions légales</a>
      <a href="#contact" class="text-white hover:text-jaune transition-colors text-sm font-display uppercase tracking-widest">Contact</a>
    </nav>

    <!-- Ligne 2 : Trait de séparation -->
    <div class="border-t border-white/20 mb-8 w-full"></div>

    <!-- Ligne 3 : Grille ajustée pour mobile -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start lg:items-center">
      
      <!-- Élément 1 : Logo -->
      <div class="lg:col-span-2 flex justify-start">
        <a href="/">
          <img src="/logo.svg" alt="Be Drippy Logo" class="h-10 w-auto" />
        </a>
      </div>

      <!-- Élément 2 : Slogan -->
      <div class="lg:col-span-5 flex justify-start">
        <p class="text-white text-corp-lg leading-snug">
          L’intelligence artificielle au service de votre style quotidien.
        </p>
      </div>

      <!-- Élément 3 : Contact & Copyright -->
      <div class="lg:col-span-3 flex flex-col justify-center gap-1">
        <a href="mailto:contact@bedrippy.fr" class="text-white hover:text-jaune transition-colors text-corp-lg break-all">
          contact@bedrippy.fr
        </a>
        <p class="text-white/70 text-sm mt-1">
          © Be Drippy
        </p>
      </div>

      <!-- Élément 4 : Réseaux sociaux -->
      <div class="lg:col-span-2 flex justify-start lg:justify-end gap-6">
        <!-- X / Twitter -->
        <a href="#" class="text-white hover:text-jaune transition-transform hover:scale-110">
          <span class="sr-only">X (Twitter)</span>
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <!-- Facebook -->
        <a href="#" class="text-white hover:text-jaune transition-transform hover:scale-110">
          <span class="sr-only">Facebook</span>
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
        </a>
        <!-- Instagram -->
        <a href="#" class="text-white hover:text-jaune transition-transform hover:scale-110">
          <span class="sr-only">Instagram</span>
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
      </div>
      
    </div>

  </div>
</footer>