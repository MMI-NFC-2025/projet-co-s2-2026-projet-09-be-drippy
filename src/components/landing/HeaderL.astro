---
/* src/components/HeaderL.astro */
---
<header class="fixed top-6 left-0 right-0 z-50 px-6 mx-auto w-full max-w-[1400px] pointer-events-none">
  
  <div id="main-header-container" class="bg-bleu-marine rounded-full shadow-2xl px-10 py-4 flex items-center justify-between pointer-events-auto border border-white/10 relative z-[70] transition-opacity duration-300">
    
    <div id="header-logo" class="flex-1 flex items-center z-[80]">
      <a href="/" class="inline-block hover:opacity-80 transition-opacity mt-1">
        <img src="/logo.svg" alt="Logo Be Drippy" class="h-9 w-auto max-w-none" />
      </a>
    </div>

    <div id="header-content" class="hidden lg:flex flex-1 items-center justify-center transition-opacity duration-300">
        <nav class="flex justify-center items-center gap-12">
            <a href="/apropos" class="font-display text-white uppercase text-corp-md tracking-wider hover:text-jaune transition-colors whitespace-nowrap">À propos</a>
            <a href="/faq" class="font-display text-white uppercase text-corp-md tracking-wider hover:text-jaune transition-colors whitespace-nowrap">FAQ</a>
            <a href="/contact" class="font-display text-white uppercase text-corp-md tracking-wider hover:text-jaune transition-colors whitespace-nowrap">Contact</a>
        </nav>
    </div>

    <div class="hidden lg:flex flex-1 justify-end items-center gap-6">
        <a href="/app/login" class="font-display text-white uppercase text-corp-md tracking-wider px-6 py-2.5 rounded-full border border-white hover:bg-white hover:text-bleu-marine transition-all whitespace-nowrap">Se connecter</a>
        <a href="/app/register" class="bg-jaune text-bleu-marine font-display uppercase text-corp-md tracking-wider px-8 py-2.5 rounded-full hover:scale-105 transition-transform whitespace-nowrap">Créer un compte</a>
    </div>

    <button id="menu-toggle" class="lg:hidden flex flex-col justify-center items-end gap-1.5 h-10 w-10 pointer-events-auto z-[80]">
      <span id="line1" class="block w-8 h-[2px] bg-white rounded-full transition-all duration-300"></span>
      <span id="line2" class="block w-5 h-[2px] bg-white rounded-full transition-all duration-300"></span>
      <span id="line3" class="block w-8 h-[2px] bg-white rounded-full transition-all duration-300"></span>
    </button>
  </div>

  <div id="menu-overlay" class="fixed inset-0 bg-bleu-marine -translate-y-full transition-transform duration-500 ease-in-out z-[65] flex flex-col items-center justify-center gap-8 pointer-events-none">
    <div class="flex flex-col items-center gap-8 pointer-events-auto">
      <a href="/" class="mb-4">
      </a>
      
      <a href="/apropos" class="menu-link text-white font-display text-3xl uppercase">À propos</a>
      <a href="/faq" class="menu-link text-white font-display text-3xl uppercase">FAQ</a>
      <a href="/contact" class="menu-link text-white font-display text-3xl uppercase">Contact</a>
      
      <div class="w-full h-[1px] bg-white/20 my-4 max-w-[200px]"></div>

      <a href="/login" class="menu-link text-white font-display text-2xl uppercase border border-white px-8 py-3 rounded-full">Se connecter</a>
      <a href="/register" class="menu-link bg-jaune text-bleu-marine font-display text-2xl uppercase px-8 py-3 rounded-full">Créer un compte</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-toggle');
  const overlay = document.getElementById('menu-overlay');
  const headerContent = document.getElementById('header-content');
  const links = document.querySelectorAll('.menu-link');
  const l1 = document.getElementById('line1');
  const l2 = document.getElementById('line2');
  const l3 = document.getElementById('line3');

  function toggleMenu() {
    overlay?.classList.toggle('-translate-y-full');
    overlay?.classList.toggle('pointer-events-none');
    headerContent?.classList.toggle('opacity-0'); 
    
    l1?.classList.toggle('rotate-45');
    l1?.classList.toggle('translate-y-[8px]');
    l2?.classList.toggle('opacity-0');
    l3?.classList.toggle('-rotate-45');
    l3?.classList.toggle('-translate-y-[8px]');
    document.body.classList.toggle('overflow-hidden');
  }

  btn?.addEventListener('click', toggleMenu);
  links.forEach(link => link.addEventListener('click', toggleMenu));
</script>

<style>
  #line1, #line2, #line3 { transform-origin: center; transition: all 0.3s ease-in-out; }
</style>