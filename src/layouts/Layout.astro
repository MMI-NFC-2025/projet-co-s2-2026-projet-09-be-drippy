---
import '../styles/global.css';
import HeaderL from '../components/HeaderL.astro';
import FooterL from '../components/FooterL.astro';

interface Props {
  title?: string;
}
const { title = "Landing Page" } = Astro.props;
---
<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-bleu-marine font-body antialiased">
    <HeaderL />
    <main>
      <slot />
    </main>
    <FooterL /> </body>
</html>