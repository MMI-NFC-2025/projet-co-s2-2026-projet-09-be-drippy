---
/* src/pages/app/register.astro */
import AppLayout from '../../layouts/AppLayout.astro';
import { register } from '../../../backend/auth.js';

let error = "";

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const email = data.get("email")?.toString() || "";
  const password = data.get("password")?.toString() || "";
  const passwordConfirm = data.get("passwordConfirm")?.toString() || "";
  const ageConfirm = data.get("ageConfirm");

  if (password !== passwordConfirm) {
    error = "Les mots de passe ne correspondent pas.";
  } else if (!ageConfirm) {
    error = "Vous devez certifier votre âge.";
  } else {
    try {
      await register(email, password);
      // Redirection vers la page de connexion après une inscription réussie
      return Astro.redirect('/app/login'); 
    } catch (e) {
      error = "Erreur lors de la création du compte. Cet email est peut-être déjà utilisé.";
    }
  }
}
---

<AppLayout title="Inscription">
  
  <!-- On utilise bg-bleu-claire de ton global.css -->
  <div class="fixed inset-0 z-50 bg-bleu-claire flex flex-col items-center justify-end lg:justify-center overflow-hidden">
    
    <!-- Logo Be Drippy -->
    <div class="absolute top-10 w-full flex justify-center lg:hidden z-0 pointer-events-none">
      <img src="/logo.svg" alt="Logo Be Drippy" class="w-48 drop-shadow-md" />
    </div>

    <!-- Conteneur principal (La carte Responsive) -->
    <div class="w-full md:max-w-md lg:max-w-5xl h-[85vh] lg:h-[650px] flex flex-col lg:flex-row relative lg:bg-bleu-marine lg:rounded-[3rem] lg:shadow-2xl lg:overflow-hidden">
      
      <!-- 1. Le cercle bleu foncé (z-0) -->
      <!-- On utilise lg:bg-bleu-claire pour la partie ordi -->
      <div class="w-full aspect-square lg:aspect-auto lg:h-full lg:w-1/2 bg-bleu-marine rounded-full lg:rounded-none z-0 relative flex flex-col items-center justify-center lg:bg-bleu-claire">
        
        <!-- Contenu Desktop : Le grand logo centré -->
        <div class="hidden lg:flex flex-col items-center justify-center z-20">
          <img src="/logo.svg" alt="Logo Be Drippy" class="w-72" />
        </div>

        <!-- Contenu Mobile : Bouton Retour et Titre -->
        <div class="absolute top-[12%] w-full flex flex-col items-center justify-center lg:hidden z-20">
          <a href="/app/auth" class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-bleu-marine shadow-md transition-transform active:scale-95 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
          </a>
          <h2 class="text-white text-[24px] font-black">Créer votre compte</h2>
        </div>
        
      </div>

      <!-- 3. Le rectangle bleu foncé (z-20) -->
      <div class="w-full flex-grow bg-bleu-marine z-20 relative -mt-[50%] lg:mt-0 lg:w-1/2 flex flex-col">
        
        <!-- Espaceur mathématique (Uniquement sur mobile) -->
        <div class="w-full pt-[15%] lg:hidden shrink-0 pointer-events-none"></div>

        <!-- Zone du formulaire -->
        <div class="w-full flex-grow flex flex-col justify-start lg:justify-center items-center px-8 lg:px-16 relative z-30 pb-6 lg:pb-0">
          
          <!-- En-tête Desktop (Bouton retour + Titre) : Caché sur mobile -->
          <div class="hidden lg:flex w-full items-center gap-4 mb-6">
            <a href="/app/auth" class="w-12 h-12 bg-white rounded-full flex items-center justify-center text-bleu-marine shadow-md hover:bg-gray-100 transition-colors shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
              </svg>
            </a>
            <h2 class="text-white text-[28px] font-black">Créer votre compte</h2>
          </div>

          <!-- Le Formulaire d'inscription -->
          <form method="POST" class="flex flex-col gap-4 w-full mt-2 lg:mt-0">
            
            <div class="flex flex-col gap-1 w-full">
              <label for="email" class="text-white font-bold text-base ml-1">Email</label>
              <!-- Utilisation de focus:ring-bleu-claire -->
              <input type="email" name="email" id="email" placeholder="votre@email.com" required 
                class="p-3.5 rounded-full text-bleu-marine font-medium bg-white focus:outline-none focus:ring-4 focus:ring-bleu-claire/50 w-full placeholder:text-gray-400 shadow-inner" />
            </div>
            
            <div class="flex flex-col gap-1 w-full">
              <label for="password" class="text-white font-bold text-base ml-1">Mot de passe</label>
              <input type="password" name="password" id="password" placeholder="••••••••" required 
                class="p-3.5 rounded-full text-bleu-marine font-medium bg-white focus:outline-none focus:ring-4 focus:ring-bleu-claire/50 w-full placeholder:text-gray-400 shadow-inner" />
            </div>

            <div class="flex flex-col gap-1 w-full">
              <label for="passwordConfirm" class="text-white font-bold text-base ml-1">Confirmer le mot de passe</label>
              <input type="password" name="passwordConfirm" id="passwordConfirm" placeholder="••••••••" required 
                class="p-3.5 rounded-full text-bleu-marine font-medium bg-white focus:outline-none focus:ring-4 focus:ring-bleu-claire/50 w-full placeholder:text-gray-400 shadow-inner" />
            </div>

            <!-- Case à cocher pour l'âge (AGRANDIE) -->
            <div class="flex items-center gap-4 w-full mt-2">
              
              <!-- Checkbox agrandie avec les variables globales (checked:bg-jaune) -->
              <input type="checkbox" name="ageConfirm" id="ageConfirm" required 
                class="appearance-none w-7 h-7 lg:w-8 lg:h-8 rounded-full bg-white shrink-0 cursor-pointer checked:ring-4 checked:ring-bleu-claire/50 checked:bg-jaune transition-all" />
              
              <!-- Rectangle agrandi (p-4) et texte plus lisible (text-sm). -->
              <!-- ATTENTION : Remplace 'bg-rouge' par le nom exact de ta variable si c'est différent dans ton global.css (ex: bg-saumon) -->
              <label for="ageConfirm" class="bg-rouge text-white text-sm lg:text-base leading-snug p-4 rounded-2xl cursor-pointer flex-1 shadow-sm">
                Je certifie avoir <span class="font-bold">15 ans ou plus</span>, ou disposer de l'accord parental pour utiliser BE DRIPPY
              </label>

            </div>

            <!-- Message d'erreur utilisant text-jaune -->
            {error && <p class="text-jaune font-bold text-center text-sm mt-1">{error}</p>}

            <!-- Bouton utilisant bg-jaune -->
            <button type="submit" class="w-full bg-jaune hover:bg-yellow-200 text-bleu-marine font-extrabold text-xl py-4 rounded-full text-center transition-all active:scale-95 shadow-md mt-2">
              Continuer
            </button>
            
          </form>
          
        </div>
        
      </div>
      
    </div>
    
  </div>
</AppLayout>