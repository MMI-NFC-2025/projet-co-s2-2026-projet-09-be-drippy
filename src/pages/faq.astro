---
import LandingLayout from '../layouts/LandingLayout.astro';

const questions = [
  {
    q: "Comment fonctionne l'analyse météo ?",
    a: "Be Drippy se connecte à des API météorologiques en temps réel. Notre algorithme croise ensuite les conditions (température, vent, humidité) avec les caractéristiques techniques de vos vêtements pour vous proposer la tenue idéale."
  },
  {
    q: "Est-ce que je dois prendre chaque vêtement en photo ?",
    a: "Oui, la prise de photo est nécessaire pour numériser votre vestiaire. Cependant, notre IA s'occupe de tagger automatiquement la couleur, la matière et le type de vêtement pour vous faire gagner un temps précieux."
  },
  {
    q: "L'application est-elle gratuite ?",
    a: "Nous proposons une version 'Basic' gratuite et complète. Pour accéder à des fonctionnalités avancées, comme le calendrier des tenues ou le réseau social, nous proposons une offre 'Premium' à 4.99€ par mois."
  },
  {
    q: "Mes données sont-elles protégées ?",
    a: "Absolument. Vos photos et vos informations personnelles sont stockées de manière sécurisée et ne sont jamais revendues à des tiers. Votre vestiaire numérique est privé."
  }
];
---

<LandingLayout title="FAQ">

  <div class="flex flex-col w-full -mt-32 relative z-10 mb-12 lg:mb-16">
    
    <section class="w-full h-[40vh] lg:h-[50vh] relative z-0">
      <img src="/img/herolanding.avif" alt="FAQ Be Drippy" class="absolute inset-0 w-full h-full object-cover object-center" />
    </section>

    <section class="grille relative z-10 mt-12 lg:mt-16">
      
      <div class="col-full bg-bleu-claire rounded-[32px] p-10 lg:p-16 relative">
        
        <h1 class="font-display text-titre-sm lg:text-titre-md text-bleu-marine text-center leading-tight mb-12">
          Questions fréquentes
        </h1>

        <div class="flex flex-col gap-6 w-full">
          {questions.map((item) => (
            <details class="group bg-white rounded-[24px] p-6 lg:p-8 transition-all duration-300 w-full">
              <summary class="font-display text-titre-sm text-bleu-marine cursor-pointer list-none flex justify-between items-center">
                {item.q}
                <span class="text-[#38bdf8] transition-transform group-open:rotate-180">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </span>
              </summary>
              <p class="text-corp-md lg:text-corp-lg text-bleu-marine/90 mt-4 leading-relaxed font-semibold">
                {item.a}
              </p>
            </details>
          ))}
        </div>
        
      </div>
      
    </section>

    <section class="grille relative z-10 mt-12 lg:mt-16">
      <div class="col-full bg-bleu-marine rounded-[32px] p-10 lg:p-16 flex flex-col lg:flex-row items-center justify-between gap-10 shadow-2xl relative overflow-hidden">
        
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-jaune/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-bleu-claire/10 rounded-full blur-3xl pointer-events-none"></div>

        <div class="flex flex-col items-start text-left lg:w-2/3 relative z-10">
          <h2 class="font-display text-titre-sm lg:text-titre-md text-white leading-tight mb-4">
            D'autres questions ?
          </h2>
          <p class="text-corp-md lg:text-corp-lg text-white/80 max-w-2xl font-semibold">
            N'hésitez pas à nous contacter directement via notre formulaire ou sur nos réseaux sociaux.
          </p>
        </div>
        
        <div class="lg:w-1/3 flex justify-start lg:justify-end w-full relative z-10">
          <a href="/contact" class="bg-jaune text-bleu-marine font-display text-corp-md uppercase tracking-wider px-10 py-5 rounded-full hover:scale-105 transition-transform text-center w-full md:w-auto">
            Nous contacter
          </a>
        </div>
      </div>
    </section>

  </div>

</LandingLayout>