---
/* src/pages/index.astro */
import LandingLayout from '../layouts/LandingLayout.astro';
---

<LandingLayout title="Accueil">

  <!-- mb-12 lg:mb-16 garantit que l'espace avant le footer sera le même qu'entre les cartes -->
  <div class="flex flex-col w-full -mt-32 relative z-10 mb-12 lg:mb-16">
    
    <section class="w-full h-[60vh] lg:h-[70vh] relative z-0">
      <img 
        src="/img/herolanding.avif" 
        alt="Fond Hero Be Drippy" 
        class="absolute inset-0 w-full h-full object-cover object-center"
      />
    </section>

    <!-- SECTION CARD 1 (Bleue) -->
    <section class="grille relative z-10 mt-12 lg:mt-16">
      
      <div class="col-full bg-bleu-claire rounded-[32px] p-10 lg:p-16 flex flex-col lg:flex-row items-center gap-12 relative">
        
        <div class="lg:w-1/2 flex flex-col items-start gap-6 relative z-20">
          
          <h1 class="font-display text-titre-sm lg:text-titre-md text-bleu-marine leading-tight">
            Ne vous laissez plus surprendre par la météo
          </h1>
          
          <p class="text-corp-md lg:text-corp-lg text-bleu-marine/90 leading-relaxed font-medium max-w-sm lg:max-w-md">
            Be Drippy analyse les prévisions heure par heure pour vous suggérer la tenue parfaite. 
            Fini la panique du matin ou les regrets de l'après-midi : votre style s'adapte en temps réel.
          </p>
          
          <a href="/register" class="mt-4 bg-jaune text-bleu-marine font-display text-corp-md uppercase tracking-wider px-8 py-4 lg:px-10 lg:py-5 rounded-full hover:scale-105 transition-transform">
            Démarrer mon vestiaire intelligent
          </a>
          
        </div>

        <div class="lg:w-1/2 flex justify-center lg:justify-end w-full relative">
          <img 
            src="/smartphone.png" 
            alt="Interface de l'application Be Drippy" 
            class="w-[280px] lg:w-[340px] h-auto object-contain relative -mt-32 lg:-mt-56 lg:-mb-12 z-30"
          />
        </div>
        
      </div>
      
    </section>

    <!-- SECTION CARD 2 (Jaune) -->
    <section class="grille relative z-10 mt-12 lg:mt-16">
      
      <div class="col-full bg-jaune rounded-[32px] p-8 lg:p-16 relative overflow-hidden flex items-center justify-center">
        
        <div class="hidden lg:flex absolute top-[55%] left-0 w-full items-center z-0 px-4">
          <div class="h-[3px] bg-white flex-1"></div>
          <svg class="w-10 h-10 text-white -ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 5l7 7-7 7"></path>
          </svg>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8 w-full relative z-10">
          
          <div class="bg-bleu-claire rounded-[32px] p-6 lg:p-8 flex flex-col gap-6">
            <h3 class="font-display text-titre-sm lg:text-titre-md text-bleu-marine text-center leading-tight">
              Numérisez votre<br/>vestiaire
            </h3>
            <div class="bg-white rounded-[24px] p-6 lg:p-8 flex-1">
              <p class="text-bleu-marine text-corp-md lg:text-corp-lg leading-relaxed text-left">
                Prenez quelques photos pour transformer votre armoire en catalogue numérique. Notre IA organise automatiquement vos vêtements pour vous permettre de visualiser tout votre vestiaire en un instant, sans fouiller vos tiroirs.
              </p>
            </div>
          </div>

          <div class="bg-bleu-claire rounded-[32px] p-6 lg:p-8 flex flex-col gap-6">
            <h3 class="font-display text-titre-sm lg:text-titre-md text-bleu-marine text-center leading-tight">
              L'intelligence<br/>météo
            </h3>
            <div class="bg-white rounded-[24px] p-6 lg:p-8 flex-1 border-[3px] border-[#38bdf8]">
              <p class="text-bleu-marine text-corp-md lg:text-corp-lg leading-relaxed text-left">
                Notre algorithme croise la météo en temps réel avec votre inventaire. Température, vent ou pluie : Be Drippy sélectionne uniquement les pièces adaptées pour vous garantir confort et style tout au long de la journée.
              </p>
            </div>
          </div>

          <div class="bg-bleu-claire rounded-[32px] p-6 lg:p-8 flex flex-col gap-6">
            <h3 class="font-display text-titre-sm lg:text-titre-md text-bleu-marine text-center leading-tight">
              Partagez votre<br/>Drippy
            </h3>
            <div class="bg-white rounded-[24px] p-6 lg:p-8 flex-1">
              <p class="text-bleu-marine text-corp-md lg:text-corp-lg leading-relaxed text-left">
                Rejoignez la communauté pour sauvegarder et diffuser vos meilleurs looks. Validez vos choix auprès de vos amis, consultez votre historique et inspirez-vous des tendances locales partagées par les autres utilisateurs.
              </p>
            </div>
          </div>

        </div>

      </div>

    </section>

    <!-- SECTION BANDE DÉFILANTE -->
    <section class="w-full bg-bleu-marine py-6 mt-12 lg:mt-16 overflow-hidden flex whitespace-nowrap border-y border-white/10 relative">
      <div class="animate-marquee flex gap-12 lg:gap-16 items-center px-6 lg:px-8">
        <span class="font-display text-titre-sm lg:text-titre-md text-jaune uppercase tracking-widest">Garde-robe Intelligente</span>
        <span class="text-white text-titre-sm lg:text-titre-md">✦</span>
        <span class="font-display text-titre-sm lg:text-titre-md text-jaune uppercase tracking-widest">Météo en temps réel</span>
        <span class="text-white text-titre-sm lg:text-titre-md">✦</span>
        <span class="font-display text-titre-sm lg:text-titre-md text-jaune uppercase tracking-widest">Style sur-mesure</span>
        <span class="text-white text-titre-sm lg:text-titre-md">✦</span>
        <span class="font-display text-titre-sm lg:text-titre-md text-jaune uppercase tracking-widest">IA Vestimentaire</span>
        <span class="text-white text-titre-sm lg:text-titre-md">✦</span>
        <span class="font-display text-titre-sm lg:text-titre-md text-jaune uppercase tracking-widest">Outfit of the day</span>
        <span class="text-white text-titre-sm lg:text-titre-md">✦</span>
      </div>
      <div class="animate-marquee flex gap-12 lg:gap-16 items-center px-6 lg:px-8" aria-hidden="true">
        <span class="font-display text-titre-sm lg:text-titre-md text-jaune uppercase tracking-widest">Garde-robe Intelligente</span>
        <span class="text-white text-titre-sm lg:text-titre-md">✦</span>
        <span class="font-display text-titre-sm lg:text-titre-md text-jaune uppercase tracking-widest">Météo en temps réel</span>
        <span class="text-white text-titre-sm lg:text-titre-md">✦</span>
        <span class="font-display text-titre-sm lg:text-titre-md text-jaune uppercase tracking-widest">Style sur-mesure</span>
        <span class="text-white text-titre-sm lg:text-titre-md">✦</span>
        <span class="font-display text-titre-sm lg:text-titre-md text-jaune uppercase tracking-widest">IA Vestimentaire</span>
        <span class="text-white text-titre-sm lg:text-titre-md">✦</span>
        <span class="font-display text-titre-sm lg:text-titre-md text-jaune uppercase tracking-widest">Outfit of the day</span>
        <span class="text-white text-titre-sm lg:text-titre-md">✦</span>
      </div>
    </section>

    <!-- SECTION OFFRES -->
    <section class="grille relative z-10 mt-12 lg:mt-16">
      
      <div class="col-full bg-bleu-claire rounded-[32px] p-8 lg:p-16 flex flex-col items-center relative">
        
        <h2 class="font-display text-titre-sm lg:text-titre-md text-bleu-marine mb-4 text-center leading-tight">
          Choisissez votre style
        </h2>
        <p class="text-corp-md lg:text-corp-lg text-bleu-marine/80 text-center max-w-2xl mb-12">
          Que vous cherchiez simplement à vous organiser ou à inspirer toute la communauté, nous avons l'offre qu'il vous faut.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full max-w-5xl">
          
          <div class="bg-white rounded-[24px] p-8 lg:p-10 flex flex-col border border-transparent hover:border-bleu-marine/10 transition-colors shadow-sm hover:shadow-md">
            <h3 class="font-display text-titre-sm lg:text-titre-md text-bleu-marine mb-2">Basic Drippy</h3>
            <div class="flex items-end gap-2 mb-8">
              <span class="font-display text-titre-lg text-bleu-marine leading-none">0€</span>
              <span class="text-corp-md text-bleu-marine/60 mb-1">/mois</span>
            </div>
            
            <ul class="flex flex-col gap-4 flex-1 mb-0">
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-[#38bdf8] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-corp-md lg:text-corp-lg text-bleu-marine">Garde-robe numérique illimitée</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-[#38bdf8] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-corp-md lg:text-corp-lg text-bleu-marine">Auto-tagging IA par photo</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-[#38bdf8] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-corp-md lg:text-corp-lg text-bleu-marine">Algorithme météo basique</span>
              </li>
              <li class="flex items-start gap-3 opacity-40">
                <svg class="w-6 h-6 text-bleu-marine shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                <span class="text-corp-md lg:text-corp-lg text-bleu-marine">Accès au réseau social</span>
              </li>
            </ul>
          </div>

          <div class="bg-bleu-marine rounded-[24px] p-8 lg:p-10 flex flex-col relative shadow-xl transform md:-translate-y-4">
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-jaune text-bleu-marine font-display text-corp-md uppercase tracking-widest py-1.5 px-6 rounded-full shadow-md">
              Le plus populaire
            </div>

            <h3 class="font-display text-titre-sm lg:text-titre-md text-white mb-2 mt-2">Premium Drippy</h3>
            <div class="flex items-end gap-2 mb-8">
              <span class="font-display text-titre-lg text-jaune leading-none">4.99€</span>
              <span class="text-corp-md text-white/60 mb-1">/mois</span>
            </div>
            
            <ul class="flex flex-col gap-4 flex-1 mb-0">
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-jaune shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-corp-md lg:text-corp-lg text-white">Tout de l'offre Basic</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-jaune shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-corp-md lg:text-corp-lg text-white">Accès exclusif au réseau social</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-jaune shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-corp-md lg:text-corp-lg text-white">Calendrier complet des tenues</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-jaune shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-corp-md lg:text-corp-lg text-white">Algorithme météo prédictif (Heure/Heure)</span>
              </li>
            </ul>
          </div>

        </div>
        
      </div>
      
    </section>

    <!-- SECTION CALL TO ACTION FINAL -->
    <section class="grille relative z-10 mt-12 lg:mt-16">
      <div class="col-full bg-bleu-marine rounded-[32px] p-10 lg:p-16 flex flex-col lg:flex-row items-center justify-between gap-10 shadow-2xl relative overflow-hidden">
        
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-jaune/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-bleu-claire/10 rounded-full blur-3xl pointer-events-none"></div>

        <div class="flex flex-col items-start text-left lg:w-2/3 relative z-10">
          <h2 class="font-display text-titre-sm lg:text-titre-md text-white leading-tight mb-4">
            Prêt à révolutionner vos matins ?
          </h2>
          <p class="text-corp-md lg:text-corp-lg text-white/80 max-w-2xl">
            Rejoignez Be Drippy dès aujourd'hui et laissez notre intelligence artificielle composer vos meilleures tenues.
          </p>
        </div>
        
        <div class="lg:w-1/3 flex justify-start lg:justify-end w-full relative z-10">
          <!-- Ombres retirées ici (shadow-xl shadow-jaune/20) -->
          <a href="/register" class="bg-jaune text-bleu-marine font-display text-corp-md uppercase tracking-wider px-10 py-5 rounded-full hover:scale-105 transition-transform text-center w-full md:w-auto">
            Démarrer mon vestiaire
          </a>
        </div>
        
      </div>
    </section>

  </div>

</LandingLayout>

<style>
  .animate-marquee {
    animation: marquee 25s linear infinite;
  }

  @keyframes marquee {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-100%); }
  }
</style>